# Minimal ArduPlane SITL defaults for the CyberPhysics airplane simulation.
# Vehicle-specific airframe tuning belongs outside this generic config.
ARMING_CHECK 1
AHRS_EKF_TYPE 3
EK3_ENABLE 1
ARSPD_USE 0
ARSPD_TYPE 0
TECS_SYNAIRSPEED 1
TECS_SPDWEIGHT 1.0
AIRSPEED_CRUISE 19
MIN_GROUNDSPEED 12
RTL_ALTITUDE 120
WP_RADIUS 60
ROLL_LIMIT_DEG 45
PTCH_LIM_MAX_DEG 20
PTCH_LIM_MIN_DEG -25
FS_SHORT_ACTN 0
FS_LONG_ACTN 1
