# Airplane values for the shared BlueOS navigation core
# (compositions/blueos_nav_core.yaml), pulled in via the include env_file
# in compositions/airplane_hardware.yaml. This file is the single source
# of truth for the airplane hardware deployment's topology and scenario.

# Identity / topology
VEHICLE_NAMESPACE=plane0
MAVROS_CONTAINER=airplane_mavros
OAK1_CONTAINER=airplane_downward_camera
DEMNAV_CONTAINER=airplane_demnav
WILDNAV_CONTAINER=airplane_wildnav
ROSBRIDGE_CONTAINER=airplane_rosbridge
CAMERA_TOPIC_ROOT=/airplane/downward
CAMERA_FRAME_ID=airplane/downward_optical_frame
NAVIGATION_ODOM_TOPIC=/airplane/navigation/odometry
DEMNAV_CACHE_HOST=/data/airplane_demnav_cache
WILDNAV_CACHE_HOST=/data/airplane_wildnav_cache
BLUEOS_FCU_URL=udp://0.0.0.0:14550@

# Scenario
INITIAL_LAT=37.9234
INITIAL_LON=-122.5967
ORIGIN_ALT=280.0
AREA_KM=12.0
SEARCH_RADIUS_M=1200.0
FOV_DEG=69.0

# WildNav tuning (fixed-wing: wider search, more tiles, larger jumps)
WILDNAV_ZOOM=17
WILDNAV_SEARCH_RADIUS_M=1200.0
WILDNAV_MAX_TILES=81
WILDNAV_MAX_DOWNLOADS=8
WILDNAV_FEATURE_BACKEND=SIFT
WILDNAV_RATE_HZ=0.2
WILDNAV_MIN_MATCHES=18
WILDNAV_MIN_INLIERS=12
WILDNAV_MAX_JUMP_M=350.0
DEMNAV_FUSION_CONFIDENCE=0.35
WILDNAV_FUSION_CONFIDENCE=0.20
