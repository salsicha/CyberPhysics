<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="so101">
  <xacro:arg name="use_gazebo" default="false"/>
  <xacro:arg name="controllers_file" default=""/>

  <material name="so101_gray"><color rgba="0.22 0.24 0.27 1"/></material>
  <material name="so101_blue"><color rgba="0.08 0.38 0.72 1"/></material>
  <material name="so101_black"><color rgba="0.03 0.03 0.03 1"/></material>

  <xacro:macro name="box_link" params="name sx sy sz mass color:=so101_gray">
    <link name="${name}">
      <inertial>
        <origin xyz="0 0 0"/>
        <mass value="${mass}"/>
        <inertia ixx="${mass * (sy * sy + sz * sz) / 12.0}" ixy="0" ixz="0"
                 iyy="${mass * (sx * sx + sz * sz) / 12.0}" iyz="0"
                 izz="${mass * (sx * sx + sy * sy) / 12.0}"/>
      </inertial>
      <visual><geometry><box size="${sx} ${sy} ${sz}"/></geometry><material name="${color}"/></visual>
      <collision><geometry><box size="${sx} ${sy} ${sz}"/></geometry></collision>
    </link>
  </xacro:macro>

  <link name="world"/>
  <xacro:box_link name="base_link" sx="0.12" sy="0.12" sz="0.045" mass="0.42" color="so101_black"/>
  <joint name="world_to_base" type="fixed">
    <parent link="world"/><child link="base_link"/><origin xyz="0 0 0.0225"/>
  </joint>

  <xacro:box_link name="shoulder_link" sx="0.07" sy="0.07" sz="0.085" mass="0.22" color="so101_blue"/>
  <joint name="shoulder_pan" type="revolute">
    <parent link="base_link"/><child link="shoulder_link"/>
    <origin xyz="0 0 0.065"/><axis xyz="0 0 1"/>
    <limit lower="-1.9199" upper="1.9199" effort="6.0" velocity="3.0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <link name="upper_arm_link">
    <inertial><origin xyz="0 0 0.07"/><mass value="0.28"/><inertia ixx="0.00055" ixy="0" ixz="0" iyy="0.00055" iyz="0" izz="0.00012"/></inertial>
    <visual><origin xyz="0 0 0.07"/><geometry><box size="0.055 0.055 0.14"/></geometry><material name="so101_gray"/></visual>
    <collision><origin xyz="0 0 0.07"/><geometry><box size="0.055 0.055 0.14"/></geometry></collision>
  </link>
  <joint name="shoulder_lift" type="revolute">
    <parent link="shoulder_link"/><child link="upper_arm_link"/>
    <origin xyz="0 0 0.045"/><axis xyz="0 1 0"/>
    <limit lower="-1.7453" upper="1.7453" effort="6.0" velocity="3.0"/>
    <dynamics damping="0.08" friction="0.02"/>
  </joint>

  <link name="forearm_link">
    <inertial><origin xyz="0 0 0.065"/><mass value="0.24"/><inertia ixx="0.00040" ixy="0" ixz="0" iyy="0.00040" iyz="0" izz="0.00010"/></inertial>
    <visual><origin xyz="0 0 0.065"/><geometry><box size="0.05 0.05 0.13"/></geometry><material name="so101_blue"/></visual>
    <collision><origin xyz="0 0 0.065"/><geometry><box size="0.05 0.05 0.13"/></geometry></collision>
  </link>
  <joint name="elbow_flex" type="revolute">
    <parent link="upper_arm_link"/><child link="forearm_link"/>
    <origin xyz="0 0 0.14"/><axis xyz="0 1 0"/>
    <limit lower="-1.7453" upper="1.7453" effort="6.0" velocity="3.0"/>
    <dynamics damping="0.07" friction="0.02"/>
  </joint>

  <xacro:box_link name="wrist_pitch_link" sx="0.05" sy="0.05" sz="0.065" mass="0.13" color="so101_gray"/>
  <joint name="wrist_flex" type="revolute">
    <parent link="forearm_link"/><child link="wrist_pitch_link"/>
    <origin xyz="0 0 0.13"/><axis xyz="0 1 0"/>
    <limit lower="-1.6581" upper="1.6581" effort="3.0" velocity="4.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <xacro:box_link name="wrist_roll_link" sx="0.045" sy="0.045" sz="0.06" mass="0.11" color="so101_blue"/>
  <joint name="wrist_roll" type="revolute">
    <parent link="wrist_pitch_link"/><child link="wrist_roll_link"/>
    <origin xyz="0 0 0.055"/><axis xyz="0 0 1"/>
    <limit lower="-2.7439" upper="2.7439" effort="3.0" velocity="4.0"/>
    <dynamics damping="0.04" friction="0.01"/>
  </joint>

  <xacro:box_link name="gripper_base_link" sx="0.075" sy="0.045" sz="0.045" mass="0.10" color="so101_black"/>
  <joint name="wrist_to_gripper" type="fixed">
    <parent link="wrist_roll_link"/><child link="gripper_base_link"/><origin xyz="0 0 0.052"/>
  </joint>

  <xacro:box_link name="gripper_jaw_link" sx="0.018" sy="0.025" sz="0.075" mass="0.035" color="so101_blue"/>
  <joint name="gripper" type="prismatic">
    <parent link="gripper_base_link"/><child link="gripper_jaw_link"/>
    <origin xyz="0.025 0 0.035"/><axis xyz="1 0 0"/>
    <limit lower="0.0" upper="0.04" effort="2.0" velocity="0.15"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

  <link name="fixed_jaw_link">
    <visual><origin xyz="-0.025 0 0.035"/><geometry><box size="0.018 0.025 0.075"/></geometry><material name="so101_blue"/></visual>
    <collision><origin xyz="-0.025 0 0.035"/><geometry><box size="0.018 0.025 0.075"/></geometry></collision>
  </link>
  <joint name="fixed_jaw_joint" type="fixed">
    <parent link="gripper_base_link"/><child link="fixed_jaw_link"/>
  </joint>

  <link name="groot_camera_link">
    <visual><geometry><box size="0.035 0.025 0.025"/></geometry><material name="so101_black"/></visual>
    <collision><geometry><box size="0.035 0.025 0.025"/></geometry></collision>
  </link>
  <joint name="base_to_groot_camera" type="fixed">
    <parent link="base_link"/><child link="groot_camera_link"/>
    <origin xyz="0.24 -0.28 0.34" rpy="0.0 0.72 2.36"/>
  </joint>
  <link name="groot_camera_rgb_optical_frame"/>
  <joint name="groot_camera_optical_joint" type="fixed">
    <parent link="groot_camera_link"/><child link="groot_camera_rgb_optical_frame"/>
    <origin xyz="0 0 0" rpy="-1.57079632679 0 -1.57079632679"/>
  </joint>

  <ros2_control name="SO101System" type="system">
    <hardware><plugin>gz_ros2_control/GazeboSimSystem</plugin></hardware>
    <joint name="shoulder_pan"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
    <joint name="shoulder_lift"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
    <joint name="elbow_flex"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
    <joint name="wrist_flex"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
    <joint name="wrist_roll"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
    <joint name="gripper"><command_interface name="position"/><state_interface name="position"><param name="initial_value">0.0</param></state_interface><state_interface name="velocity"/></joint>
  </ros2_control>

  <xacro:if value="$(arg use_gazebo)">
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>$(arg controllers_file)</parameters>
      </plugin>
    </gazebo>
  </xacro:if>
</robot>
