INITIAL_LAT=37.9234
INITIAL_LON=-122.5967
ORIGIN_ALT=280.0
# Override these if your AS2 Gazebo assets publish different camera names.
DRONE_NAMESPACE=drone_sim_0
GPS_TOPIC=/drone_sim_0/sensor_measurements/gps
ODOM_TOPIC=/drone_sim_0/sensor_measurements/odom
RAW_ODOM_TOPIC=/drone_sim_0/sensor_measurements/odom
POSE_TOPIC=/drone_sim_0/ground_truth/pose
TWIST_TOPIC=/drone_sim_0/ground_truth/twist
NAVIGATION_ODOM_TOPIC=/navigation/odometry
DEMNAV_ODOM_TOPIC=/demnav/odometry
DEPTH_TOPIC=/drone_sim_0/sensor_measurements/downward_rgbd/depth
CAMERA_INFO_TOPIC=/drone_sim_0/sensor_measurements/downward_rgbd/depth/camera_info
WILDNAV_IMAGE_TOPIC=/drone_sim_0/sensor_measurements/downward_rgb/image_raw
WILDNAV_CAMERA_INFO_TOPIC=/drone_sim_0/sensor_measurements/downward_rgb/camera_info

# Wilderness scenario contract: systems/aerostack2_gazebo/scenarios/mount_tamalpais_wilderness.json
GPS_STANDARD_TOPIC=/navigation/gps_standard
OAK_IMAGE_TOPIC=/oak1/image_highres
OAK_IMAGE_INFO_TOPIC=/oak1/image_highres/camera_info
OAK_RELATIVE_DEPTH_TOPIC=/oak1/relative_depth
OAK_DEPTH_INFO_TOPIC=/oak1/camera_info
RANGEFINDER_TOPIC=/aerodrone/rangefinder
BATTERY_TOPIC=/aerodrone/battery_voltage
RC_FAILSAFE_TOPIC=/aerodrone/rc_failsafe
GEOFENCE_TOPIC=/aerodrone/geofence_violation
EMERGENCY_LAND_TOPIC=/aerodrone/emergency_land
